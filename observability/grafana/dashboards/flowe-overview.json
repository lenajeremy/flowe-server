{
  "uid": "flowe-overview",
  "title": "Flowe · Service Overview",
  "tags": ["flowe"],
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count{job=\"flowe-server\"}[$__rate_interval]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request latency p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error ratio (5xx %)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(http_server_request_duration_seconds_count{job=\"flowe-server\", http_response_status_code=~\"5..\"}[$__rate_interval])) or vector(0)) / sum(rate(http_server_request_duration_seconds_count{job=\"flowe-server\"}[$__rate_interval]))",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Active HTTP requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(http_server_active_requests{job=\"flowe-server\"})",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "p95 latency by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (http_route, le) (rate(http_server_request_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Goroutines",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "go_goroutine_count{job=\"flowe-server\"}",
          "legendFormat": "goroutines"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Go memory used by type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (go_memory_type) (go_memory_used_bytes{job=\"flowe-server\"})",
          "legendFormat": "{{go_memory_type}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "DB pool connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "flowe_db_pool_connections{job=\"flowe-server\"}",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 24 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"flowe-server\"}"
        }
      ]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Errors / Warnings",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 24 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"flowe-server\"} | severity_text=~\"ERROR|WARN\""
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Requests by status code",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 33 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count{job=\"flowe-server\"}[$__rate_interval]))",
          "legendFormat": "{{http_response_status_code}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Log volume by level",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warn" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "debug" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (detected_level) (count_over_time({service_name=\"flowe-server\"} [$__auto]))",
          "legendFormat": "{{detected_level}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "DB query p95 by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 33 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(flowe_db_query_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Auth events by event",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 33 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event) (rate(flowe_auth_events_total{job=\"flowe-server\"}[$__rate_interval]))",
          "legendFormat": "{{event}}"
        }
      ]
    }
  ]
}
