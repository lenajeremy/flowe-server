{
  "uid": "flowe-workflows",
  "title": "Flowe · Workflow Engine",
  "tags": ["flowe"],
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Workflow runs (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(flowe_workflow_runs_total{job=\"flowe-server\"}[24h]))",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error runs (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(flowe_workflow_runs_total{job=\"flowe-server\", status=\"error\"}[24h]))",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active runs",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(flowe_workflow_runs_active{job=\"flowe-server\"})"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Runs per minute by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(flowe_workflow_runs_total{job=\"flowe-server\"}[$__rate_interval])) * 60",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Runs per minute by trigger",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (trigger) (rate(flowe_workflow_runs_total{job=\"flowe-server\"}[$__rate_interval])) * 60",
          "legendFormat": "{{trigger}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Run duration p50 / p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(flowe_workflow_run_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(flowe_workflow_run_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Node executions/s by type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (node_type) (rate(flowe_node_executions_total{job=\"flowe-server\"}[$__rate_interval]))",
          "legendFormat": "{{node_type}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Node p95 duration by type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (node_type, le) (rate(flowe_node_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "{{node_type}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Node error ratio by type (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (node_type) (rate(flowe_node_executions_total{job=\"flowe-server\", status=\"error\"}[$__rate_interval])) / sum by (node_type) (rate(flowe_node_executions_total{job=\"flowe-server\"}[$__rate_interval]))",
          "legendFormat": "{{node_type}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Outbound HTTP rate by host",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (server_address) (rate(http_client_request_duration_seconds_count{job=\"flowe-server\"}[$__rate_interval]))",
          "legendFormat": "{{server_address}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Outbound HTTP p95 by host",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (server_address, le) (rate(http_client_request_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "{{server_address}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Error logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 28 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"flowe-server\"} | severity_text=~\"ERROR|WARN\""
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "LLM calls/min by model",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "fieldConfig": {
        "defaults": { "unit": "cpm", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model) (rate(flowe_llm_calls_total{job=\"flowe-server\"}[$__rate_interval])) * 60",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "LLM p95 duration by model",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(flowe_llm_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "LLM errors/min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "fieldConfig": {
        "defaults": { "unit": "cpm", "min": 0, "custom": { "fillOpacity": 20 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider, model) (rate(flowe_llm_calls_total{job=\"flowe-server\", status=\"error\"}[$__rate_interval])) * 60",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Integration ops/min by provider/operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 45 },
      "fieldConfig": {
        "defaults": { "unit": "cpm", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider, operation) (rate(flowe_integration_calls_total{job=\"flowe-server\"}[$__rate_interval])) * 60",
          "legendFormat": "{{provider}}/{{operation}}"
        }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Integration error ratio by provider (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 45 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (provider) (rate(flowe_integration_calls_total{job=\"flowe-server\", status=\"error\"}[$__rate_interval])) / sum by (provider) (rate(flowe_integration_calls_total{job=\"flowe-server\"}[$__rate_interval]))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Integration p95 duration by provider",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 45 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(flowe_integration_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 19,
      "type": "stat",
      "title": "Approvals pending",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 53 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(flowe_approvals_pending{job=\"flowe-server\"}) or vector(0)"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Approvals resolved/min by result",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 53 },
      "fieldConfig": {
        "defaults": { "unit": "cpm", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(flowe_approvals_resolved_total{job=\"flowe-server\"}[$__rate_interval])) * 60",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Approval wait p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 53 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(flowe_approval_wait_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Run events/min by type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 61 },
      "fieldConfig": {
        "defaults": { "unit": "cpm", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (rate(flowe_run_events_total{job=\"flowe-server\"}[$__rate_interval])) * 60",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "SSE streams by kind",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 61 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (flowe_sse_streams{job=\"flowe-server\"})",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Webhooks & schedule fires/min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 61 },
      "fieldConfig": {
        "defaults": { "unit": "cpm", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(flowe_webhooks_received_total{job=\"flowe-server\"}[$__rate_interval])) * 60",
          "legendFormat": "webhook · {{status}}"
        },
        {
          "refId": "B",
          "expr": "sum by (status) (rate(flowe_schedule_fires_total{job=\"flowe-server\"}[$__rate_interval])) * 60",
          "legendFormat": "schedule · {{status}}"
        }
      ]
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "Emails sent/min by kind/status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 69 },
      "fieldConfig": {
        "defaults": { "unit": "cpm", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind, status) (rate(flowe_emails_sent_total{job=\"flowe-server\"}[$__rate_interval])) * 60",
          "legendFormat": "{{kind}}/{{status}}"
        }
      ]
    }
  ]
}
