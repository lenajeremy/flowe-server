{
  "uid": "flowe-debug",
  "title": "Flowe · Logs & Debugging",
  "tags": ["flowe"],
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Panics (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(flowe_panics_total{job=\"flowe-server\"}[24h])) or vector(0)",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Hub dropped events (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(flowe_hub_dropped_total{job=\"flowe-server\"}[24h])) or vector(0)",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Template misses (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(flowe_template_misses_total{job=\"flowe-server\"}[24h])) or vector(0)",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Open SSE streams",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(flowe_sse_streams{job=\"flowe-server\"}) or vector(0)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Log volume by level",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warn" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "debug" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (detected_level) (count_over_time({service_name=\"flowe-server\"} [$__auto]))",
          "legendFormat": "{{detected_level}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests by status class",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "2xx" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_class) (label_replace(rate(http_server_request_duration_seconds_count{job=\"flowe-server\"}[$__rate_interval]), \"status_class\", \"${1}xx\", \"http_response_status_code\", \"([0-9])..\"))",
          "legendFormat": "{{status_class}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Error & warning logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 12 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"flowe-server\"} | detected_level=~\"error|warn\""
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "HTTP access log",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 12 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"flowe-server\"} |= \"http request\""
        }
      ]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Outbound HTTP",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 21 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"flowe-server\"} |= \"outbound http\""
        }
      ]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Workflow lifecycle",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 21 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"flowe-server\"} |= \"workflow run\""
        }
      ]
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Slow DB queries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"flowe-server\"} |= \"slow db query\""
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "4xx / 5xx rate by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_route, http_response_status_code) (rate(http_server_request_duration_seconds_count{job=\"flowe-server\", http_response_status_code=~\"4..|5..\"}[$__rate_interval]))",
          "legendFormat": "{{http_route}} · {{http_response_status_code}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Rate-limit hits by scope",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 38 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (scope) (rate(flowe_ratelimit_hits_total{job=\"flowe-server\"}[$__rate_interval]))",
          "legendFormat": "{{scope}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Unauthorized events",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 38 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "min": 0, "custom": { "fillOpacity": 20 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(flowe_auth_events_total{job=\"flowe-server\", event=\"unauthorized\"}[$__rate_interval]))",
          "legendFormat": "unauthorized ({{status}})"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "DB query p95 by operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 38 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(flowe_db_query_duration_seconds_bucket{job=\"flowe-server\"}[$__rate_interval])))",
          "legendFormat": "{{operation}}"
        }
      ]
    }
  ]
}
